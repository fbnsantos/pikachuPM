{
  "manifest_version": 3,
  "name": "pikachuPM Todos",
  "version": "1.1.0",
  "description": "Gere os teus todos do pikachuPM diretamente do browser.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "pikachuPM Todos",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "options_page": "options.html",
  "permissions": [
    "storage",
    "sidePanel",
    "windows"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
