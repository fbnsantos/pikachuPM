{
  "manifest_version": 2,
  "name": "pikachuPM Todos",
  "version": "1.2.0",
  "description": "Gere os teus todos do pikachuPM diretamente do browser.",
  "browser_specific_settings": {
    "gecko": {
      "id": "pikachupm-todos@inesctec.pt",
      "strict_min_version": "89.0"
    }
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "pikachuPM Todos",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "sidebar_action": {
    "default_title": "pikachuPM",
    "default_panel": "sidebar.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "background": {
    "scripts": ["mqtt.min.js", "background.js"],
    "persistent": true
  },
  "options_ui": {
    "page": "options.html",
    "browser_style": false
  },
  "permissions": [
    "storage",
    "notifications",
    "tabs"
  ],
  "optional_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
